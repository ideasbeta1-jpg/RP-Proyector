{
  "name": "rp-proyector",
  "version": "1.0.0",
  "description": "Proyector de Biblia, canciones y anuncios para la Iglesia Pentecostal",
  "main": "./out/main/index.js",
  "author": "RP Proyector",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "build:win": "npm run build && electron-builder --win",
    "build:portable": "npm run build && electron-builder --win portable",
    "import-songs": "set ELECTRON_RUN_AS_NODE=1 && electron scripts/scrape-songs.cjs",
    "import-songs:test": "set ELECTRON_RUN_AS_NODE=1 && electron scripts/scrape-songs.cjs --test"
  },
  "build": {
    "appId": "org.iglesiapentecostal.rpproyector",
    "productName": "RP Proyector",
    "copyright": "Copyright © 2026 Iglesia Pentecostal",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources/bible",
        "to": "bible",
        "filter": [
          "**/*.json"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RP Proyector"
    },
    "publish": {
      "provider": "github",
      "owner": "rinconpentecostal",
      "repo": "rp-proyector"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@types/react-window": "^1.8.8",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.8.9",
    "react-window": "^1.8.11",
    "uuid": "^14.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.1",
    "@tailwindcss/vite": "^4.1.13",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "immer": "^10.1.1",
    "lucide-react": "^0.511.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.8.0",
    "vite": "^5.4.0",
    "zustand": "^5.0.8"
  }
}
